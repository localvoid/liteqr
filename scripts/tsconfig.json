{
  "compilerOptions": {
    "noEmit": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "lib": ["ES2024"],
    "types": ["node", "bun"],
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
